# ============================================================
# Konfigurasi M3 Chicken POS Backend
# Salin file ini menjadi `.env` lalu sesuaikan nilainya.
# ============================================================

# Port server (Hostinger biasanya mengatur PORT otomatis)
PORT=3000

# Driver database: "sqlite" (lokal/offline) atau "mysql" (server/Hostinger)
DB_DRIVER=sqlite

# --- Konfigurasi MySQL (hanya dipakai bila DB_DRIVER=mysql) ---
# Ambil nilai ini dari hPanel Hostinger > Databases > MySQL Databases
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=u123456789_kasir
MYSQL_PASSWORD=ganti_dengan_password
MYSQL_DATABASE=u123456789_m3chicken
